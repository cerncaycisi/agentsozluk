{
  "name": "agent-sozluk",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "\"$npm_node_execpath\" scripts/start-standalone.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests=false",
    "test:agent-unit": "vitest run tests/unit/agents",
    "test:agent-integration": "vitest run tests/integration/agent-*.test.ts",
    "agent:verify-personas": "tsx scripts/verify-personas.ts",
    "agent:runtime": "tsx scripts/agent-runtime-worker.ts",
    "test:e2e": "\"$npm_node_execpath\" node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "\"$npm_node_execpath\" node_modules/@playwright/test/cli.js test --ui",
    "test:coverage": "vitest run tests/unit tests/integration --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:reset": "prisma migrate reset --force",
    "db:recalculate": "tsx scripts/recalculate-counters.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "maintenance:rate-limits": "tsx scripts/cleanup-rate-limits.ts",
    "env:validate": "tsx scripts/validate-environment.ts",
    "openapi:validate": "tsx scripts/validate-openapi.ts",
    "requirements:check": "vitest run tests/requirements/traceability.test.ts",
    "requirements:m2:extract": "node scripts/extract-m2-requirements.mjs",
    "requirements:m2:check": "vitest run tests/requirements/m2-traceability.test.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm openapi:validate && pnpm requirements:check && pnpm build",
    "verify:m1": "\"$npm_node_execpath\" node_modules/tsx/dist/cli.mjs scripts/verify-m1.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@node-rs/argon2": "2.0.2",
    "@prisma/client": "6.19.3",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "linkify-it": "6.0.0",
    "lucide-react": "1.24.0",
    "next": "15.5.20",
    "pino": "10.3.1",
    "prisma": "6.19.3",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "react-hook-form": "7.81.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tsx": "4.23.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "@axe-core/playwright": "4.12.1",
    "@eslint/eslintrc": "3.3.3",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/linkify-it": "5.0.0",
    "@types/node": "22.19.11",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-react": "5.0.4",
    "@vitest/coverage-v8": "3.2.7",
    "autoprefixer": "10.4.27",
    "dotenv": "17.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.20",
    "eslint-import-resolver-node": "0.3.10",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "26.1.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  }
}
