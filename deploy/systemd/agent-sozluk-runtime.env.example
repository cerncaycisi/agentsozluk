# This file contains only non-secret runtime settings and paths.
# Never place agent credentials, Codex authentication data, application secrets,
# database URLs, passwords, tokens or private keys in this EnvironmentFile.
AGENT_RUNTIME_BASE_URL=http://127.0.0.1:3000
AGENT_RUNTIME_CREDENTIAL_FILE=/var/lib/agent-sozluk-runtime/credentials.json
AGENT_RUNTIME_CODEX_HOME=/opt/agent-sozluk/runtime/codex-home
AGENT_RUNTIME_WORK_ROOT=/opt/agent-sozluk/runtime/work
AGENT_RUNTIME_WORKER_ID=production-runtime-01
AGENT_RUNTIME_POLL_MS=5000
CODEX_EXECUTABLE=/usr/local/bin/codex
CODEX_SANDBOX_EXECUTABLE=/usr/bin/bwrap
LOG_LEVEL=info
